@page "/game/{GameId:int}"

@using System.Net.Http
@using Football.Application.Features.Games.Models
@using Football.Application.Features.Plays.Models
@using Football.Application.Features.Stats.Models
@using Football.Blazor.Components
@using Football.Infrastructure.Exceptions

@inherits GameComponentBase

<div class="mdc-layout-grid__inner">
    <div class="mdc-layout-grid__cell mdc-layout-grid__cell--span-2-tablet mdc-layout-grid__cell--span-4-desktop"></div>
    <!-- Back button row -->
    <div class="mdc-layout-grid__cell mdc-layout-grid__cell--span-2-tablet mdc-layout-grid__cell--span-4-desktop">
        <NavLink href="/">
            <span class="mdc-typography--body2">Back</span>
        </NavLink>
    </div>
    <div class="mdc-layout-grid__cell mdc-layout-grid__cell--span-2-tablet mdc-layout-grid__cell--span-4-desktop"></div>
    @if (hubConnectionFailed)
    {
        <div class="mdc-layout-grid__cell mdc-layout-grid__cell--span-12">
            <div style="text-align: center; padding: 20px;">
                <p class="mdc-typography--body1">An error occurred. Live score updates are unavailable.</p>
                <button class="mdc-button mdc-button--raised" @onclick="ReloadPage">
                    <span class="mdc-button__label">Reload</span>
                </button>
            </div>
        </div>
    }
    @if (playToUpdate is null && !loadFailed && !hubConnectionFailed)
    {
        <div class="mdc-layout-grid__cell mdc-layout-grid__cell--span-12" style="text-align: center; padding: 40px;">
            <div class="mdc-circular-progress mdc-circular-progress--indeterminate" style="width:48px;height:48px;" role="progressbar" aria-label="Loading..." aria-valuemin="0" aria-valuemax="1">
                <div class="mdc-circular-progress__determinate-container">
                    <svg class="mdc-circular-progress__determinate-circle-graphic" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                        <circle class="mdc-circular-progress__determinate-circle" cx="24" cy="24" r="18" stroke-dasharray="113.097" stroke-dashoffset="113.097"/>
                    </svg>
                </div>
                <div class="mdc-circular-progress__indeterminate-container">
                    <div class="mdc-circular-progress__spinner-layer">
                        <div class="mdc-circular-progress__circle-clipper mdc-circular-progress__circle-left">
                            <svg class="mdc-circular-progress__indeterminate-circle-graphic" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="24" cy="24" r="18" stroke-dasharray="113.097" stroke-dashoffset="56.549"/>
                            </svg>
                        </div>
                        <div class="mdc-circular-progress__gap-patch">
                            <svg class="mdc-circular-progress__indeterminate-circle-graphic" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="24" cy="24" r="18" stroke-dasharray="113.097" stroke-dashoffset="56.549"/>
                            </svg>
                        </div>
                        <div class="mdc-circular-progress__circle-clipper mdc-circular-progress__circle-right">
                            <svg class="mdc-circular-progress__indeterminate-circle-graphic" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="24" cy="24" r="18" stroke-dasharray="113.097" stroke-dashoffset="56.549"/>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (playToUpdate is null)
    {
        <div class="mdc-layout-grid__cell mdc-layout-grid__cell--span-12">
            <div style="text-align: center; padding: 20px;">
                <p class="mdc-typography--body1">An error occurred. The game could not be loaded.</p>
                <button class="mdc-button mdc-button--raised" @onclick="RetryLoadGame">
                    <span class="mdc-button__label">Retry</span>
                </button>
            </div>
        </div>
    }
    else
    {
        <!-- GameCast title -->
        <div class="mdc-layout-grid__cell mdc-layout-grid__cell--span-12" style="text-align:center">
            <span class="mdc-typography--body2">@playToUpdate.AwayTeam @@ @playToUpdate.HomeTeam</span>
        </div>
        <!-- GameCast layout -->
        <div class="mdc-layout-grid__cell mdc-layout-grid__cell--span-2-tablet mdc-layout-grid__cell--span-4-desktop"></div>
        <div class="mdc-layout-grid__cell mdc-layout-grid__cell--span-4-tablet mdc-layout-grid__cell--span-4-desktop">
            <div class="mdc-layout-grid__inner">
                <div class="mdc-layout-grid__cell mdc-layout-grid__cell--span-8-tablet mdc-layout-grid__cell--span-12-desktop">
                    <GameCard GameId="@playToUpdate.GameId" Play="@playToUpdate" />
                </div>
            </div>
        </div>
        <div class="mdc-layout-grid__cell mdc-layout-grid__cell--span-2-tablet mdc-layout-grid__cell--span-4-desktop"></div>
        <!-- GameCast title -->
        <div class="mdc-layout-grid__cell mdc-layout-grid__cell--span-12" style="text-align:center">
            <span class="mdc-typography--body2">Stats</span>
        </div>
        <!-- GameStats layout -->
        <StatsTable Team="@playToUpdate.HomeTeam" TeamStats=@homeTeamStats />
        <StatsTable Team="@playToUpdate.AwayTeam" TeamStats=@awayTeamStats />
    }
</div>

@code {
    private bool hubConnectionFailed = false;

    private PlayDto? playToUpdate = null;

    private StatDto? homeTeamStats = null;

    private StatDto? awayTeamStats = null;

    [Parameter]
    public int GameId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            HttpClient httpClient = HttpClientFactory.CreateClient(Constants.DefaultHttpClient);
            GameDto? game = await httpClient.GetFromJsonAsync<GameDto>($"games/{GameId}");

            if (game is null) throw new Exception("Game not found.");

            playToUpdate = GetPlayFromGame(game);

            GameStatDto? gameStats = await httpClient.GetFromJsonAsync<GameStatDto>($"games/{GameId}/stats");
            homeTeamStats = gameStats?.Stats.Find(s => s.Home);
            awayTeamStats = gameStats?.Stats.Find(s => !s.Home);

            await InitializeHubConnection(async (playReceived) =>
            {
                if (GameId == playReceived.GameId)
                {
                    playToUpdate = new PlayDto
                    {
                        Id = playReceived.Id,
                        HomeTeam = playReceived.HomeTeam,
                        HomeScore = playReceived.HomeScore,
                        AwayTeam = playReceived.AwayTeam,
                        AwayScore = playReceived.AwayScore,
                        Quarter = playReceived.Quarter,
                        QuarterSecondsRemaining = playReceived.QuarterSecondsRemaining,
                        Description = playReceived.Description
                    };

                    GameStatDto? updatedGameStats = await httpClient.GetFromJsonAsync<GameStatDto>($"games/{GameId}/stats");
                    homeTeamStats = updatedGameStats?.Stats.Find(s => s.Home);
                    awayTeamStats = updatedGameStats?.Stats.Find(s => !s.Home);

                    StateHasChanged();
                }
            });
        }
        catch (HubException ex)
        {
            hubConnectionFailed = true;
            Logger.LogError(ex, "GameCast page: There was an error initializing the Hub connection.");
        }
        catch (Exception ex)
        {
            loadFailed = true;
            Logger.LogError(ex, "GameCast page: There was an error loading the game data.");
        }
    }

    private async Task RetryLoadGame()
    {
        loadFailed = false;
        hubConnectionFailed = false;
        playToUpdate = null;
        await OnInitializedAsync();
    }

    private void ReloadPage()
    {
        NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
    }
}
